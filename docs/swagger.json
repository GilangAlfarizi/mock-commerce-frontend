		"/products": {
			"get": {
				"description": "Paginated active products. pageSize default 20 max 50. sort: newest, price_asc, price_desc. categorySlugs: OR filter, comma or repeated",
				"produces": ["application/json"],
				"tags": ["public-products"],
				"summary": "List products (public)",
				"parameters": [
					{
						"type": "integer",
						"description": "Page (default 1)",
						"name": "page",
						"in": "query"
					},
					{
						"type": "integer",
						"description": "Page size (default 20, max 50)",
						"name": "pageSize",
						"in": "query"
					},
					{
						"type": "string",
						"description": "newest, price_asc, price_desc",
						"name": "sort",
						"in": "query"
					},
					{
						"type": "string",
						"description": "Category slugs, comma-separated or repeat param",
						"name": "categorySlugs",
						"in": "query"
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"schema": {
							"$ref": "#/definitions/dto.PublicProductListResponse"
						}
					},
					"500": {
						"description": "Internal Server Error",
						"schema": {
							"$ref": "#/definitions/dto.APIResponse"
						}
					}
				}
			}
		},
		"/products/{slug}": {
			"get": {
				"description": "Active product detail by public slug; includes variants",
				"produces": ["application/json"],
				"tags": ["public-products"],
				"summary": "Get product by slug (public)",
				"parameters": [
					{
						"type": "string",
						"description": "Product slug",
						"name": "slug",
						"in": "path",
						"required": true
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"schema": {
							"$ref": "#/definitions/dto.PublicProductResponse"
						}
					},
					"404": {
						"description": "Not Found",
						"schema": {
							"$ref": "#/definitions/dto.APIResponse"
						}
					},
					"500": {
						"description": "Internal Server Error",
						"schema": {
							"$ref": "#/definitions/dto.APIResponse"
						}
					}
				}
			}
		},
		"/register": {
			"post": {
				"description": "Create a new user account",
				"consumes": ["application/json"],
				"produces": ["application/json"],
				"tags": ["auth"],
				"summary": "Register a new user",
